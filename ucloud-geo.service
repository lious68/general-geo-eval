[Unit]
Description=UCloud GEO Evaluation API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/ucloud-geo-eval/backend
ExecStart=/usr/local/bin/uvicorn app:app --host 0.0.0.0 --port 8000 --workers 1
Restart=always
RestartSec=5
Environment=PYTHONPATH=/opt/ucloud-geo-eval/backend:/opt/ucloud-geo-eval/core

[Install]
WantedBy=multi-user.target
