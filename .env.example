# UCloud GEO Evaluation - API Keys Configuration
# 复制此文件为 .env 并填入你的 API keys: cp .env.example .env
#
# 💡 推荐优先注册 DeepSeek（最便宜，1元/百万tokens）和 Kimi（注册送额度）
# 🎮 不想配置API？先运行 python main.py --demo 看演示效果

# ================================================================
# DeepSeek (深度求索)
# 注册: https://platform.deepseek.com/
# 价格: 输入 1元/百万tokens, 输出 2元/百万tokens
# 模型: deepseek-chat (默认), deepseek-v4-flash, deepseek-v4-pro
# ================================================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ================================================================
# 文心一言 ERNIE (百度千帆)
# 注册: https://console.bce.baidu.com/qianfan/
# 新用户送20元代金券
# 价格: ernie-4.0-8k 输入120/输出120元/百万tokens; ernie-speed 免费
# ================================================================
ERNIE_API_KEY=your_ernie_api_key_here

# ================================================================
# 豆包 Doubao (火山引擎)
# 注册: https://console.volcengine.com/ark
# 需要在Ark控制台创建"推理接入点"获取 endpoint ID
# 创建后修改 config.py 中 doubao.model 为 ep-xxxxxxxx
# ================================================================
DOUBAO_API_KEY=your_doubao_api_key_here

# ================================================================
# Kimi (月之暗面/Moonshot AI)
# 注册: https://platform.moonshot.cn/
# 价格: 输入 12/输出 12元/百万tokens
# ================================================================
KIMI_API_KEY=your_kimi_api_key_here

# ================================================================
# 通义千问 QWEN (阿里云百炼)
# 注册: https://dashscope.console.aliyun.com/
# 价格: qwen-plus 输入4/输出12元/百万tokens; qwen-turbo 0.3/0.6元
# ================================================================
QWEN_API_KEY=your_qwen_api_key_here
